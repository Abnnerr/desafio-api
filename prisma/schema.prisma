generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model motorista {
  id        Int      @id @default(autoincrement())
  nome      String
  documento String   @unique
  veiculo   veiculo?

  @@index([nome])
  @@index([documento])
}

model veiculo {
  id          Int       @id @default(autoincrement())
  placa       String    @unique
  marca       String
  modelo      String
  ano         String
  motoristaId Int    @unique
  motorista   motorista @relation(fields: [motoristaId], references: [id], onDelete: Cascade)

  @@index([placa])
}
